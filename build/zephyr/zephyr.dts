	/* node '/clock' defined in zephyr/dts/xtensa/espressif/esp32s3/esp32s3_common.dtsi:82 */
	clock: clock {
		compatible = "espressif,esp32-clock"; /* in zephyr/dts/xtensa/espressif/esp32s3/esp32s3_common.dtsi:83 */
		fast-clk-src = < 0x1 >;               /* in zephyr/dts/xtensa/espressif/esp32s3/esp32s3_common.dtsi:84 */
		slow-clk-src = < 0x0 >;               /* in zephyr/dts/xtensa/espressif/esp32s3/esp32s3_common.dtsi:85 */
		#clock-cells = < 0x1 >;               /* in zephyr/dts/xtensa/espressif/esp32s3/esp32s3_common.dtsi:86 */
		status = "okay";                      /* in zephyr/dts/xtensa/espressif/esp32s3/esp32s3_common.dtsi:87 */
		phandle = < 0x3 >;                    /* in zephyr/dts/xtensa/espressif/esp32s3/esp32s3_common.dtsi:188 */
	};

	/* node '/buttons' defined in zephyr/boards/espressif/esp32s3_devkitc/esp32s3_devkitc_procpu.dts:37 */
	buttons {
		compatible = "gpio-keys"; /* in zephyr/boards/espressif/esp32s3_devkitc/esp32s3_devkitc_procpu.dts:38 */

		/* node '/buttons/button_0' defined in zephyr/boards/espressif/esp32s3_devkitc/esp32s3_devkitc_procpu.dts:40 */
		button0: button_0 {
			gpios = < &gpio0 0x0 0x11 >; /* in zephyr/boards/espressif/esp32s3_devkitc/esp32s3_devkitc_procpu.dts:41 */
			label = "BOOT Button";       /* in zephyr/boards/espressif/esp32s3_devkitc/esp32s3_devkitc_procpu.dts:42 */
			zephyr,code = < 0xb >;       /* in zephyr/boards/espressif/esp32s3_devkitc/esp32s3_devkitc_procpu.dts:43 */
		};
	};

	/* node '/mipi_dbi' defined in Hacktor_Basic/app.overlay:16 */
	mipi_dbi {
		compatible = "zephyr,mipi-dbi-spi"; /* in Hacktor_Basic/app.overlay:17 */
		spi-dev = < &spi3 >;                /* in Hacktor_Basic/app.overlay:18 */
		dc-gpios = < &gpio0 0x5 0x0 >;      /* in Hacktor_Basic/app.overlay:19 */
		reset-gpios = < &gpio0 0x3 0x1 >;   /* in Hacktor_Basic/app.overlay:20 */
		write-only;                         /* in Hacktor_Basic/app.overlay:21 */
		#address-cells = < 0x1 >;           /* in Hacktor_Basic/app.overlay:22 */
		#size-cells = < 0x0 >;              /* in Hacktor_Basic/app.overlay:23 */

		/* node '/mipi_dbi/gc9a01@0' defined in Hacktor_Basic/app.overlay:25 */
		gc9a01: gc9a01@0 {
			compatible = "galaxycore,gc9x01x";     /* in Hacktor_Basic/app.overlay:26 */
			reg = < 0x0 >;                         /* in Hacktor_Basic/app.overlay:27 */
			status = "okay";                       /* in Hacktor_Basic/app.overlay:28 */
			zephyr,deferred-init;                  /* in Hacktor_Basic/app.overlay:29 */
			orientation = "180";                   /* in Hacktor_Basic/app.overlay:30 */
			mipi-max-frequency = < 0x1312d00 >;    /* in Hacktor_Basic/app.overlay:31 */
			mipi-mode = "MIPI_DBI_MODE_SPI_4WIRE"; /* in Hacktor_Basic/app.overlay:32 */
			pixel-format = < 0x10 >;               /* in Hacktor_Basic/app.overlay:33 */
			width = < 0xf0 >;                      /* in Hacktor_Basic/app.overlay:34 */
			height = < 0xf0 >;                     /* in Hacktor_Basic/app.overlay:35 */
			display-inversion;                     /* in Hacktor_Basic/app.overlay:36 */
		};
	};

	/* node '/leds' defined in Hacktor_Basic/app.overlay:40 */
	leds {
		compatible = "gpio-leds"; /* in Hacktor_Basic/app.overlay:41 */

		/* node '/leds/lcd_backlight' defined in Hacktor_Basic/app.overlay:43 */
		lcd_backlight: lcd_backlight {
			gpios = < &gpio0 0x7 0x0 >; /* in Hacktor_Basic/app.overlay:44 */
			label = "LCD backlight";    /* in Hacktor_Basic/app.overlay:45 */
		};
	};
};
